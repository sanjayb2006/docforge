# DocForge — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DocForge
DEBUG=false

# ── Database (PostgreSQL via asyncpg) ─────────────────────────────────────────
DATABASE_URL: str = "sqlite+aiosqlite:///./docforge.db"
# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Generation limits ─────────────────────────────────────────────────────────
MAX_TOKENS_PER_SECTION=1500
GENERATION_TIMEOUT_SEC=120
MAX_UPLOAD_MB=50
